# ─────────────────────────────────────────
#  NEXL Website — Environment Variables
#  Copy to .env.local and fill in values
# ─────────────────────────────────────────

# Formspree form ID — get from https://formspree.io
# Replace YOUR_FORM_ID in src/components/shared/QuoteForm.jsx
VITE_FORMSPREE_ID=your_formspree_form_id

# Site URL — update before going live
VITE_SITE_URL=https://www.nexllogistics.com

# Google Analytics (optional)
VITE_GA_ID=G-XXXXXXXXXX
